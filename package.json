{
  "name": "haribote",
  "version": "0.1.0",
  "description": "Vite plugin that SSRs only meta tags, leaving the rest as CSR",
  "keywords": [
    "vite",
    "vite-plugin",
    "ssr",
    "meta",
    "seo",
    "spa",
    "csr"
  ],
  "author": {
    "name": "mimifuwacc",
    "email": "mail@mimifuwa.cc",
    "url": "https://github.com/mimifuwacc"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimifuwacc/haribote.git"
  },
  "homepage": "https://github.com/mimifuwacc/haribote#readme",
  "bugs": {
    "url": "https://github.com/mimifuwacc/haribote/issues"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "browser": "./dist/browser.mjs",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "path-to-regexp": "^8.2.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "unbuild": "^3.5.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
